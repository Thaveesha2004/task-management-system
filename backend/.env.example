# Prisma connection (Railway MySQL) — use this for db:setup
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=mysql://root:password@containers-us-west-xxx.railway.app:3306/railway

# Legacy mysql2 connection (existing backend code still uses these)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=railway
DB_SSL=true
JWT_SECRET=your_secret_key_here_change_in_production
PORT=5000
CLIENT_ORIGIN=http://localhost:5173,https://task-managemnet-system.netlify.app
