# Local development (Vite proxy — avoids CORS)
VITE_API_BASE=/api
VITE_SOCKET_URL=http://localhost:5000
# Proxy API calls to your local backend (required for delete user and other new routes)
VITE_DEV_PROXY_TARGET=http://localhost:5000

